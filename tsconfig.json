{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "exactOptionalPropertyTypes": false,
    "types": ["node"],
    "module": "Node16", 
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./tests/*"],
      "@/fixtures/*": ["./tests/fixtures/*"],
      "@/pages/*": ["./tests/pages/*"],
      "@/config/*": ["./config/*"]
    }
  },
  "include": [
    "tests/**/*",
    "config/**/*",
    "mock-app/**/*",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playwright-report",
    "test-results"
  ]
}
